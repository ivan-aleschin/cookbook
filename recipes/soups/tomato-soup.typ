// recipes/soups/tomato-soup.typ
#import "../../styles/components.typ": recipe
#import "../../styles/colors.typ": themes

#recipe(
  theme: themes.tomato,
  title: "Запечённый томатный суп с базиликом",
  description: [Уютный, бархатистый суп, который передаёт вкус позднего летнего урожая. Идеален для прохладных осенних вечеров.],
  servings: "4 порции",
  prep-time: "15 минут",
  cook-time: "45 минут",
  ingredients: (
    (amount: "1 кг",       name: "Помидоры Roma, разрезанные пополам"),
    (amount: "1 головка",  name: "Чеснок, верхушка срезана"),
    (amount: "1 шт.",      name: "Крупная луковица, разрезанная на четверти"),
    (amount: "3 ст. л.",   name: "Оливковое масло"),
    (amount: "1 стакан",   name: "Овощной бульон"),
    (amount: "½ стакана",  name: "Свежие листья базилика"),
    (amount: "3 ст. л.",   name: "Сливки 20% (по желанию)"),
    "Соль и свежемолотый чёрный перец",
    "Щепотка сахара",
  ),
  instructions: (
    "Разогрейте духовку до 200 °C. Застелите глубокий противень пергаментной бумагой.",
    "Выложите помидоры срезанной стороной вверх. Рядом положите луковицу и головку чеснока (срезом вверх). Полейте оливковым маслом, посолите и поперчите.",
    "Запекайте 40–45 минут — до мягкости и лёгкого обугливания краёв. Овощи должны карамелизоваться и отдать сок.",
    "Выньте противень из духовки. Дайте немного остыть. Выдавите зубчики чеснока из шелухи прямо в чашу блендера.",
    "Добавьте в блендер помидоры вместе со всеми соками, лук и листья базилика. Измельчите до однородной гладкой массы.",
    "Перелейте суп в кастрюлю. Влейте бульон и прогрейте на среднем огне 5 минут. Отрегулируйте консистенцию, добавив ещё бульона по вкусу.",
    "Разлейте по тарелкам. Украсьте листом базилика, каплей оливкового масла и подайте с хрустящим хлебом.",
  ),
  notes: "Для веганской версии замените сливки кокосовым молоком. Суп отлично хранится в холодильнике до 3 дней и ещё вкуснее на следующий день.",
)
